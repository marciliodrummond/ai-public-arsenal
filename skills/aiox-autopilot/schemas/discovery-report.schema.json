{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Discovery Report",
  "type": "object",
  "required": ["project_understanding", "market_research", "tech_landscape", "feasibility", "users", "decisions"],
  "properties": {
    "project_understanding": {
      "type": "object",
      "required": ["explicit_request", "real_intent", "anti_goals", "implicit_needs"],
      "properties": {
        "explicit_request": { "type": "string", "minLength": 10 },
        "real_intent": { "type": "string", "minLength": 10 },
        "anti_goals": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "implicit_needs": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "market_research": {
      "type": "object",
      "required": ["competitors", "market_trends", "gap_opportunities"],
      "properties": {
        "competitors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "strengths", "weaknesses"],
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" },
              "strengths": { "type": "array", "items": { "type": "string" } },
              "weaknesses": { "type": "array", "items": { "type": "string" } }
            }
          },
          "minItems": 1
        },
        "market_trends": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "gap_opportunities": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "tech_landscape": {
      "type": "object",
      "required": ["recommended_stack", "alternatives_considered"],
      "properties": {
        "recommended_stack": {
          "type": "object",
          "required": ["frontend", "backend", "database"],
          "properties": {
            "frontend": { "type": "string" },
            "backend": { "type": "string" },
            "database": { "type": "string" },
            "hosting": { "type": "string" },
            "auth": { "type": "string" }
          }
        },
        "alternatives_considered": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["option", "pros", "cons", "verdict"],
            "properties": {
              "option": { "type": "string" },
              "pros": { "type": "array", "items": { "type": "string" } },
              "cons": { "type": "array", "items": { "type": "string" } },
              "verdict": { "type": "string" }
            }
          },
          "minItems": 2
        }
      }
    },
    "feasibility": {
      "type": "object",
      "required": ["complexity", "estimated_stories", "risks", "mvp_recommendation"],
      "properties": {
        "complexity": { "type": "string", "enum": ["L", "M", "H"] },
        "estimated_stories": { "type": "integer", "minimum": 1 },
        "estimated_sprints": { "type": "integer", "minimum": 1 },
        "risks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["risk", "severity", "mitigation"],
            "properties": {
              "risk": { "type": "string" },
              "severity": { "type": "string", "enum": ["L", "M", "H"] },
              "mitigation": { "type": "string" }
            }
          },
          "minItems": 1
        },
        "mvp_recommendation": { "type": "string", "minLength": 20 }
      }
    },
    "users": {
      "type": "object",
      "required": ["personas", "critical_journeys"],
      "properties": {
        "personas": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "role", "goals"],
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "goals": { "type": "array", "items": { "type": "string" } },
              "pain_points": { "type": "array", "items": { "type": "string" } }
            }
          },
          "minItems": 1
        },
        "critical_journeys": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision", "rationale"],
        "properties": {
          "decision": { "type": "string" },
          "rationale": { "type": "string" },
          "alternatives": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
