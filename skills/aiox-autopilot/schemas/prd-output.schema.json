{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRD Output",
  "type": "object",
  "required": ["prd", "architecture", "frontend_spec", "metadata"],
  "properties": {
    "prd": {
      "type": "object",
      "required": ["goals", "functional_requirements", "non_functional_requirements", "epics"],
      "properties": {
        "goals": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "background": { "type": "string" },
        "functional_requirements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description"],
            "properties": {
              "id": { "type": "string", "pattern": "^FR\\d+" },
              "description": { "type": "string" },
              "priority": { "type": "string", "enum": ["MUST", "SHOULD", "COULD", "WONT"] },
              "acceptance_criteria": { "type": "string" }
            }
          },
          "minItems": 3
        },
        "non_functional_requirements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "description"],
            "properties": {
              "id": { "type": "string", "pattern": "^NFR\\d+" },
              "description": { "type": "string" }
            }
          },
          "minItems": 1
        },
        "epics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "stories"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "stories": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            }
          },
          "minItems": 1
        }
      }
    },
    "architecture": {
      "type": "object",
      "required": ["stack", "data_model", "source_tree"],
      "properties": {
        "stack": { "type": "object" },
        "data_model": { "type": "object" },
        "api_design": { "type": "object" },
        "infrastructure": { "type": "object" },
        "source_tree": { "type": "string", "minLength": 20 }
      }
    },
    "frontend_spec": {
      "type": "object",
      "required": ["design_tokens", "components", "screens"],
      "properties": {
        "design_tokens": { "type": "object" },
        "components": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "screens": { "type": "array", "items": { "type": "object" }, "minItems": 1 },
        "responsive_strategy": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["decisions"],
      "properties": {
        "decisions": { "type": "array", "items": { "type": "object" } },
        "cross_references": { "type": "object" }
      }
    }
  }
}
