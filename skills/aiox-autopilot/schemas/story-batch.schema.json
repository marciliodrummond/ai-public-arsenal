{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Story Batch",
  "type": "object",
  "required": ["waves", "total_stories", "total_waves"],
  "properties": {
    "total_stories": { "type": "integer", "minimum": 1 },
    "total_waves": { "type": "integer", "minimum": 1 },
    "estimated_total_hours": { "type": "number" },
    "waves": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["wave_number", "stories"],
        "properties": {
          "wave_number": { "type": "integer", "minimum": 1 },
          "depends_on_wave": { "type": ["integer", "null"] },
          "stories": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["story_id", "epic_id", "title", "acceptance_criteria", "files", "complexity"],
              "properties": {
                "story_id": { "type": "string" },
                "epic_id": { "type": "string" },
                "title": { "type": "string" },
                "objective": { "type": "string" },
                "acceptance_criteria": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "given", "when", "then"],
                    "properties": {
                      "id": { "type": "string" },
                      "given": { "type": "string" },
                      "when": { "type": "string" },
                      "then": { "type": "string" }
                    }
                  },
                  "minItems": 1
                },
                "technical_notes": { "type": "string" },
                "files": {
                  "type": "object",
                  "properties": {
                    "create": { "type": "array", "items": { "type": "string" } },
                    "modify": { "type": "array", "items": { "type": "string" } }
                  }
                },
                "depends_on": { "type": "array", "items": { "type": "string" } },
                "complexity": { "type": "string", "enum": ["S", "M", "L"] },
                "estimated_hours": { "type": "number" }
              }
            },
            "minItems": 1
          }
        }
      },
      "minItems": 1
    }
  }
}
