{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Commander Phase Output",
  "description": "Schema polimórfico: o Commander produz outputs diferentes dependendo da fase. Cada fase tem seu formato.",
  "type": "object",
  "required": ["phase", "phase_decision", "context_snapshot"],
  "properties": {
    "phase": {
      "type": "string",
      "enum": ["discovery_prep", "planning_prep", "sharding_prep", "dev_orchestration", "delivery_prep", "course_correction"]
    },
    "phase_decision": {
      "type": "object",
      "required": ["action", "rationale"],
      "properties": {
        "action": { "type": "string" },
        "rationale": { "type": "string" },
        "alternatives_considered": { "type": "array", "items": { "type": "string" } }
      }
    },
    "agent_briefing": {
      "type": "object",
      "description": "Compacted context for the next agent",
      "properties": {
        "target_agent": { "type": "string" },
        "mission": { "type": "string" },
        "inputs": { "type": "object" },
        "success_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    },
    "context_snapshot": {
      "type": "object",
      "required": ["project_type", "current_phase", "decisions_so_far"],
      "properties": {
        "project_type": { "type": "string", "enum": ["greenfield", "brownfield"] },
        "current_phase": { "type": "integer", "minimum": 0, "maximum": 4 },
        "decisions_so_far": { "type": "array", "items": { "type": "object" } },
        "artifacts_produced": { "type": "array", "items": { "type": "string" } },
        "stories_status": {
          "type": "object",
          "properties": {
            "total": { "type": "integer" },
            "done": { "type": "integer" },
            "in_progress": { "type": "integer" },
            "failed": { "type": "integer" }
          }
        }
      }
    },
    "error_recovery": {
      "type": "object",
      "properties": {
        "is_recovery": { "type": "boolean" },
        "failed_step": { "type": "string" },
        "failure_reason": { "type": "string" },
        "new_strategy": { "type": "string" }
      }
    }
  }
}
