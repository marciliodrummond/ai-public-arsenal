{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Implementation Result",
  "type": "object",
  "required": ["story_id", "status", "files_created", "tests", "acceptance_criteria_met"],
  "properties": {
    "story_id": { "type": "string" },
    "status": { "type": "string", "enum": ["implemented", "partial", "blocked"] },
    "files_created": { "type": "array", "items": { "type": "string" } },
    "files_modified": { "type": "array", "items": { "type": "string" } },
    "tests": {
      "type": "object",
      "required": ["total", "passed", "failed"],
      "properties": {
        "total": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" }
      }
    },
    "lint": { "type": "string", "enum": ["clean", "warnings", "errors"] },
    "build": { "type": "string", "enum": ["success", "failed"] },
    "acceptance_criteria_met": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" },
    "commits": { "type": "array", "items": { "type": "string" } }
  }
}
