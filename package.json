{
  "name": "@gutomec/ai-public-arsenal",
  "version": "4.1.0",
  "description": "Open-source skills for AI coding assistants — Squad Protocol Engine v4 with protocol-driven management, harness engineering, real validation, and dual-path discovery.",
  "author": "Luiz Gustavo Vieira Rodrigues <gutomec@yahoo.com.br> (https://github.com/gutomec)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gutomec/ai-public-arsenal.git"
  },
  "homepage": "https://github.com/gutomec/ai-public-arsenal#readme",
  "bugs": {
    "url": "https://github.com/gutomec/ai-public-arsenal/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "claude-code",
    "squads",
    "skills",
    "multi-agent",
    "orchestration",
    "ai-coding-assistants",
    "harness-engineering",
    "doom-loop-detection",
    "ralph-loop-retry"
  ],
  "main": "index.js",
  "exports": {
    "./squads": "./skills/squads/SKILL.md",
    "./aiox-autopilot": "./skills/aiox-autopilot/SKILL.md",
    "./package.json": "./package.json"
  },
  "files": [
    "skills/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "publish:npm": "npm publish --access public",
    "version": "git add -A && git commit -m 'chore: bump version to %s'",
    "postpublish": "git push && git push --tags"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "metadata": {
    "source": "GitHub (single source of truth)",
    "installCommand": "npm install @gutomec/ai-public-arsenal",
    "skillInstall": "npx skills add gutomec/ai-public-arsenal@squads",
    "githubUrl": "https://github.com/gutomec/ai-public-arsenal",
    "note": "This package always installs from GitHub. npm is a registry redirector only. GitHub is the single source of truth for all updates."
  }
}
